# ============================================================================
# TAUREAU CELTIQUE v3 - Configuration
# ============================================================================

# --- Application ---
APP_NAME="Taureau Celtique"
NODE_ENV=development
LOG_LEVEL=info

# --- Discord Bot ---
BOT_TOKEN=
CLIENT_ID=
GUILD_ID=
OWNER_USER_ID=
LOG_CHANNEL_ID=

# --- Bot API & WebSocket ---
BOT_API_PORT=3008
BOT_API_TOKEN=
BOT_WS_PORT=3009
BOT_JWT_SECRET=

# --- Database (MySQL/MariaDB) ---
DATABASE_URL="mysql://root@localhost:3306/taureau_celtique_v3"

# --- France Travail API (Annonces emploi) ---
# Inscription: https://francetravail.io/inscription
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# --- External APIs (optionnel) ---
YOUTUBE_API_KEY=
GITHUB_TOKEN=
DEVTO_API_KEY=
STACKOVERFLOW_API_KEY=

# --- Features Toggle ---
ENABLE_JOB_OFFERS=true
ENABLE_STUDI_MODERATION=true
