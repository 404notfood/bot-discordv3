  @@index([isActive])
  @@map("sql_clinic_challenges")
}

// ==================== Monitoring & System ====================

model SystemAlert {
  id         BigInt    @id @default(autoincrement())
  alertType  AlertType @map("alert_type")
  severity   Severity
  title      String    @db.VarChar(255)
  message    String    @db.Text
  data       Json?
  isResolved Boolean   @default(false) @map("is_resolved")
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz
  resolvedBy String?   @map("resolved_by") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([alertType])
  @@index([severity])
  @@index([isResolved])
  @@map("system_alerts")
}

model SystemMonitoring {
  id                BigInt           @id @default(autoincrement())
  metricType        MetricType       @map("metric_type")
  value             Decimal          @db.Decimal(10, 2)
  unit              String           @db.VarChar(10)
  thresholdWarning  Decimal?         @map("threshold_warning") @db.Decimal(10, 2)
  thresholdCritical Decimal?         @map("threshold_critical") @db.Decimal(10, 2)
  status            MonitoringStatus @default(ok)
  additionalData    Json?            @map("additional_data")
  recordedAt        DateTime         @default(now()) @map("recorded_at") @db.Timestamptz

  @@index([metricType])
  @@index([status])
  @@map("system_monitoring")
}

model ScheduledTask {
  id             BigInt     @id @default(autoincrement())
  name           String     @db.VarChar(255)
  guildId        String     @map("guild_id") @db.VarChar(50)
  cronExpression String     @map("cron_expression") @db.VarChar(100)
  actionType     ActionType @map("action_type")
  actionData     Json?      @map("action_data")
  isActive       Boolean    @default(true) @map("is_active")
  nextRun        DateTime?  @map("next_run") @db.Timestamptz
  lastRun        DateTime?  @map("last_run") @db.Timestamptz
  runCount       Int        @default(0) @map("run_count")
  lastError      String?    @map("last_error") @db.Text
  createdBy      String     @map("created_by") @db.VarChar(50)
  createdAt      DateTime?  @map("created_at") @db.Timestamptz
  updatedAt      DateTime?  @map("updated_at") @db.Timestamptz

  @@unique([name, guildId], map: "unique_task_guild")
  @@index([guildId])
  @@index([isActive])
  @@map("scheduled_tasks")
}

model Reminder {
  id        Int       @id @default(autoincrement())
  guildId   String    @map("guild_id") @db.VarChar(50)
  userId    String    @map("user_id") @db.VarChar(50)
  channelId String    @map("channel_id") @db.VarChar(50)
  message   String    @db.Text
  remindAt  DateTime  @map("remind_at") @db.Timestamptz
  repeat    String?   @db.VarChar(20)
  status    String    @default("pending") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  sentAt    DateTime? @map("sent_at") @db.Timestamptz

  @@index([guildId])
  @@index([remindAt])
  @@index([status])
  @@map("reminders")
}

// ==================== Dashboard ====================

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resourceType])
  @@map("audit_logs")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id")
  type      String
  title     String
  message   String    @db.Text
  link      String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ==================== GitHub ====================

model GithubStreak {
  id             Int       @id @default(autoincrement())
  discordId      String    @map("discord_id") @db.VarChar(20)
  githubUsername String    @map("github_username") @db.VarChar(100)
  streakDays     Int       @default(0) @map("streak_days")
  lastCommitDate DateTime? @map("last_commit_date") @db.Date
  totalRepos     Int       @default(0) @map("total_repos")
  followers      Int       @default(0)
  bestStreak     Int       @default(0) @map("best_streak")
  totalCommits   Int       @default(0) @map("total_commits")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([discordId, githubUsername])
  @@index([streakDays])
  @@index([discordId])
  @@map("github_streaks")
}

// ==================== Job Offers ====================

model JobOfferConfig {
  id               Int      @id @default(autoincrement())
  guildId          String   @unique @map("guild_id") @db.VarChar(20)
  channelId        String?  @map("channel_id") @db.VarChar(20)
  isActive         Boolean  @default(false) @map("is_active")
  keywords         String   @default("developpeur junior,dev junior,developpeur web junior,developer junior") @db.VarChar(2000)
  departments      String?  @db.VarChar(500)
  contractTypes    String   @default("CDI,CDD,MIS") @map("contract_types") @db.VarChar(200)
  includeRemote    Boolean  @default(true) @map("include_remote")
  pollInterval     Int      @default(30) @map("poll_interval")
  maxOffersPerPoll Int      @default(5) @map("max_offers_per_poll")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("job_offer_configs")
}

model JobOfferPosted {
  id           Int      @id @default(autoincrement())
  guildId      String   @map("guild_id") @db.VarChar(20)
  offerId      String   @map("offer_id") @db.VarChar(50)
  title        String   @db.VarChar(500)
  company      String?  @db.VarChar(255)
  location     String?  @db.VarChar(255)
  contractType String?  @map("contract_type") @db.VarChar(50)
  messageId    String?  @map("message_id") @db.VarChar(20)
  postedAt     DateTime @default(now()) @map("posted_at") @db.Timestamptz

  @@unique([guildId, offerId], map: "unique_guild_offer")
  @@index([guildId])
  @@index([offerId])
  @@index([postedAt])
  @@map("job_offers_posted")
}
