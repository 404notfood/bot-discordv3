// ============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum AdminLevel {
  moderator
  server
  global
}

enum ActionType {
  message
  cleanup
  stats
  health
}

enum CommandType {
  TEXT
  EMBED
  ACTION
  FORM
}

enum DifficultyLevel {
  beginner
  intermediate
  advanced
}

enum QuizDifficulty {
  easy
  medium
  hard
}

enum QuizSessionDifficulty {
  EASY
  MEDIUM
  HARD
  MIXED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
  EXTREME
}

enum ProjectType {
  web
  mobile
  game
  ai
  opensource
  other
}

enum ChannelType {
  text
  voice
}

enum ChallengeType {
  weekly
  monthly
}

enum ChallengeStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ChallengeParticipantStatus {
  REGISTERED
  IN_PROGRESS
  COMPLETED
  FAILED
  WITHDRAWN
}

enum QuizSessionStatus {
  scheduled
  announced
  running
  finished
  cancelled
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REFUSED
  IMPLEMENTED
}

enum BugStatus {
  OPEN
  INVESTIGATING
  FIXED
  WONTFIX
}

enum ModerationAction {
  ban
  unban
  kick
  mute
  warn
  timeout
  audit
  preavis
}

enum BanLevel {
  watch
  warn
  autoban
}

enum DetectionType {
  auto
  manual_add
  manual_remove
}

enum AlertType {
  system
  database
  bot
  api
}

enum Severity {
  info
  warning
  error
  critical
}

enum MetricType {
  memory
  cpu
  disk
  database
  bot_status
  api_status
}

enum MonitoringStatus {
  ok
  warning
  critical
}

enum ChannelAuditAction {
  create
  delete
  update
  permissions
}

enum LogType {
  SUGGESTION
  BUG
  MODERATION
  ERROR
  ADMIN
  ALL
}

enum DocResourceType {
  ARTICLE
  TUTORIAL
  REFERENCE
  FAQ
}

enum PermissionTargetType {
  ROLE
  MEMBER
}

// ==================== Auth ====================

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  name          String?
  image         String?
  discordId     String?  @unique @map("discord_id")
  role          UserRole @default(MEMBER)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.Text
  idToken               String?   @map("id_token") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

// ==================== Guild & Configuration ====================

model GuildConfig {
  id               BigInt    @id @default(autoincrement())
  guildId          String    @unique @map("guild_id") @db.VarChar(20)
  guildName        String    @map("guild_name") @db.VarChar(255)
  ownerId          String?   @map("owner_id") @db.VarChar(20)
  memberCount      Int       @default(0) @map("member_count")
  icon             String?   @db.VarChar(255)
  isActive         Boolean   @default(true) @map("is_active")
  prefix           String    @default("!") @db.VarChar(10)
  welcomeMessage   String?   @map("welcome_message") @db.Text
  welcomeChannelId String?   @map("welcome_channel_id") @db.VarChar(20)
  logChannelId     String?   @map("log_channel_id") @db.VarChar(20)
  modLogChannelId  String?   @map("mod_log_channel_id") @db.VarChar(20)
  adminRoleId      String?   @map("admin_role_id") @db.VarChar(20)
  moderatorRoleId  String?   @map("moderator_role_id") @db.VarChar(20)
  autoRoleId       String?   @map("auto_role_id") @db.VarChar(20)
  mutedRoleId      String?   @map("muted_role_id") @db.VarChar(20)
  preavisRoleId    String?   @map("preavis_role_id") @db.VarChar(20)
  autoModeration   Boolean   @default(false) @map("auto_moderation")
  welcomeMessages  Boolean   @default(true) @map("welcome_messages")
  autoRoles        Boolean   @default(false) @map("auto_roles")
  logging          Boolean   @default(true)
  maxWarnings      Int       @default(3) @map("max_warnings")
  muteDuration     Int       @default(10) @map("mute_duration")
  banDuration      Int       @default(0) @map("ban_duration")
  features         Json?
  settings         Json?
  permissions      Json?
  channelsConfig   Json?     @map("channels_config")
  rolesConfig      Json?     @map("roles_config")
  totalMessages    Int       @default(0) @map("total_messages")
  totalCommands    Int       @default(0) @map("total_commands")
  totalModerations Int       @default(0) @map("total_moderations")
  lastActivity     DateTime? @map("last_activity") @db.Timestamptz
  createdAt        DateTime? @map("created_at") @db.Timestamptz
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz

  @@index([guildId])
  @@index([isActive])
  @@index([ownerId])
  @@index([lastActivity])
  @@index([isActive, lastActivity])
  @@map("guild_configs")
}

model BotConfig {
  id               BigInt    @id @default(autoincrement())
  guildId          String    @unique @map("guild_id") @db.VarChar(50)
  logChannelId     String?   @map("log_channel_id") @db.VarChar(50)
  prefix           String    @default("/") @db.VarChar(10)
  language         String    @default("fr") @db.VarChar(5)
  antiStudiEnabled Boolean   @default(false) @map("anti_studi_enabled")
  customSettings   Json?     @map("custom_settings")
  updatedBy        String?   @map("updated_by") @db.VarChar(50)
  createdAt        DateTime? @map("created_at") @db.Timestamptz
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz

  @@index([guildId])
  @@map("bot_config")
}

model Server {
  id          BigInt    @id @default(autoincrement())
  discordId   String    @unique @map("discord_id") @db.VarChar(255)
  name        String    @db.VarChar(255)
  icon        String?   @db.VarChar(255)
  memberCount Int       @default(0) @map("member_count")
  features    Json?
  active      Boolean   @default(true)
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz
  createdAt   DateTime? @map("created_at") @db.Timestamptz
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz

  @@index([discordId, active])
  @@map("servers")
}

// ==================== Discord Users ====================

model DiscordUser {
  id            BigInt   @id @default(autoincrement())
  discordId     String   @unique @map("discord_id") @db.VarChar(20)
  username      String   @db.VarChar(100)
  discriminator String?  @db.VarChar(4)
  avatar        String?  @db.VarChar(255)
  globalName    String?  @map("global_name") @db.VarChar(100)
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([username])
  @@map("discord_users")
}

model GuildMember {
  id                         Int       @id @default(autoincrement())
  guildId                    String    @map("guild_id")
  userId                     String    @map("user_id")
  username                   String    @db.VarChar(100)
  displayName                String?   @map("display_name") @db.VarChar(100)
  avatar                     String?   @db.Text
  roles                      String    @db.Text
  joinedAt                   DateTime  @map("joined_at")
  premiumSince               DateTime? @map("premium_since")
  isBot                      Boolean   @default(false) @map("is_bot")
  pending                    Boolean   @default(false)
  communicationDisabledUntil DateTime? @map("communication_disabled_until")
  lastActiveAt               DateTime? @map("last_active_at")
  messageCount               Int       @default(0) @map("message_count")
  voiceMinutes               Int       @default(0) @map("voice_minutes")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
  @@index([joinedAt(sort: Desc)])
  @@map("guild_members")
}

model UserProfile {
  id                Int       @id @default(autoincrement())
  discordId         String    @unique @map("discord_id") @db.VarChar(20)
  username          String?   @db.VarChar(100)
  githubUsername    String?   @map("github_username") @db.VarChar(100)
  twitterUsername   String?   @map("twitter_username") @db.VarChar(100)
  linkedinUrl       String?   @map("linkedin_url") @db.VarChar(255)
  websiteUrl        String?   @map("website_url") @db.VarChar(255)
  bio               String?   @db.Text
  location          String?   @db.VarChar(100)
  timezone          String?   @db.VarChar(50)
  preferredLanguage String?   @default("fr") @map("preferred_language") @db.VarChar(10)
  totalXp           Int       @default(0) @map("total_xp")
  level             Int       @default(1)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([githubUsername])
  @@index([level])
  @@map("user_profiles")
}

model UserSetting {
  id                   Int       @id @default(autoincrement())
  discordId            String    @unique @map("discord_id") @db.VarChar(20)
  notificationsEnabled Boolean?  @default(true) @map("notifications_enabled")
  dmNotifications      Boolean?  @default(false) @map("dm_notifications")
  dailyReminders       Boolean?  @default(false) @map("daily_reminders")
  streakReminders      Boolean?  @default(true) @map("streak_reminders")
  privacyMode          Boolean?  @default(false) @map("privacy_mode")
  themePreference      String?   @default("default") @map("theme_preference") @db.VarChar(20)
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("user_settings")
}

model UserBadge {
  id               Int       @id @default(autoincrement())
  discordId        String    @map("discord_id") @db.VarChar(20)
  badgeType        String    @map("badge_type") @db.VarChar(50)
  badgeName        String    @map("badge_name") @db.VarChar(100)
  badgeDescription String?   @map("badge_description") @db.Text
  badgeIcon        String?   @map("badge_icon") @db.VarChar(10)
  earnedAt         DateTime? @default(now()) @map("earned_at") @db.Timestamptz
  source           String?   @db.VarChar(50)

  @@unique([discordId, badgeType, badgeName])
  @@index([discordId])
  @@index([badgeType])
  @@map("user_badges")
}

model DashboardMember {
  id        BigInt    @id @default(autoincrement())
  username  String    @unique @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  role      String    @default("member") @db.VarChar(255)
  discordId String?   @map("discord_id") @db.VarChar(255)
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login") @db.Timestamptz
  createdAt DateTime? @map("created_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  @@index([username, isActive])
  @@map("dashboard_members")
}

// ==================== Admins & Moderators ====================

model BotAdmin {
  id         BigInt     @id @default(autoincrement())
  userId     String     @map("user_id") @db.VarChar(50)
  username   String     @db.VarChar(100)
  guildId    String?    @map("guild_id") @db.VarChar(50)
  adminLevel AdminLevel @default(server) @map("admin_level")
  addedBy    String     @map("added_by") @db.VarChar(50)
  addedAt    DateTime   @default(now()) @map("added_at") @db.Timestamptz

  @@unique([userId, guildId], map: "unique_admin_guild")
  @@index([userId])
  @@index([guildId])
  @@index([adminLevel])
  @@map("bot_admins")
}

model BotModerator {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id") @db.VarChar(20)
  guildId     String?   @map("guild_id") @db.VarChar(20)
  username    String    @db.VarChar(100)
  permissions String?   @db.Text
  addedBy     String    @map("added_by") @db.VarChar(20)
  addedAt     DateTime? @default(now()) @map("added_at") @db.Timestamptz
  isActive    Boolean?  @default(true) @map("is_active")

  @@unique([userId, guildId], map: "user_guild_mod")
  @@index([guildId])
  @@index([isActive])
  @@map("bot_moderators")
}

model DashboardAccess {
  id          Int       @id @default(autoincrement())
  discordId   String    @unique @map("discord_id") @db.VarChar(20)
  username    String    @db.VarChar(100)
  isAllowed   Boolean   @default(false) @map("is_allowed")
  allowedBy   String?   @map("allowed_by") @db.VarChar(20)
  allowedAt   DateTime? @map("allowed_at")
  deniedAt    DateTime? @map("denied_at")
  lastAttempt DateTime? @map("last_attempt")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isAllowed])
  @@map("dashboard_access")
}

// ==================== Commands ====================

model DynamicCommand {
  id           Int         @id @default(autoincrement())
  guildId      String      @map("guild_id") @db.VarChar(50)
  name         String      @db.VarChar(100)
  description  String      @db.VarChar(255)
  category     String      @default("custom") @db.VarChar(50)
  type         CommandType
  responseData Json        @map("response_data")
  requiredRole String?     @map("required_role") @db.VarChar(50)
  cooldown     Int         @default(0)
  enabled      Boolean     @default(true)
  createdBy    String      @map("created_by") @db.VarChar(50)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([guildId, name])
  @@index([guildId])
  @@index([enabled])
  @@map("dynamic_commands")
}

model CommandLog {
  id            BigInt   @id @default(autoincrement())
  commandName   String   @map("command_name") @db.VarChar(100)
  userId        String   @map("user_id") @db.VarChar(50)
  guildId       String?  @map("guild_id") @db.VarChar(50)
  channelId     String?  @map("channel_id") @db.VarChar(50)
  options       Json?
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message") @db.Text
  executionTime Int?     @map("execution_time")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([commandName])
  @@index([userId])
  @@index([guildId])
  @@index([createdAt])
  @@index([success])
  @@index([guildId, createdAt])
  @@map("command_logs")
}

// ==================== Moderation ====================

model ModerationLog {
  id             BigInt           @id @default(autoincrement())
  action         ModerationAction
  userId         String           @map("user_id") @db.VarChar(50)
  moderatorId    String           @map("moderator_id") @db.VarChar(50)
  guildId        String           @map("guild_id") @db.VarChar(50)
  reason         String?          @db.Text
  durationDays   Int?             @map("duration_days")
  additionalData Json?            @map("additional_data")
  executedAt     DateTime         @default(now()) @map("executed_at") @db.Timestamptz

  @@index([userId])
  @@index([moderatorId])
  @@index([guildId])
  @@index([action])
  @@index([executedAt])
  @@map("moderation_logs")
}

model BannedUser {
  id           BigInt    @id @default(autoincrement())
  userId       String    @map("user_id") @db.VarChar(50)
  username     String    @db.VarChar(100)
  guildId      String    @map("guild_id") @db.VarChar(50)
  reason       String?   @db.Text
  bannedBy     String    @map("banned_by") @db.VarChar(50)
  executedAt   DateTime? @map("executed_at") @db.Timestamptz
  durationDays Int?      @map("duration_days")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  unbannedBy   String?   @map("unbanned_by") @db.VarChar(50)
  unbannedAt   DateTime? @map("unbanned_at") @db.Timestamptz
  unbanReason  String?   @map("unban_reason") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime? @map("created_at") @db.Timestamptz
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz

  @@index([isActive, expiresAt])
  @@map("banned_users")
}

// ==================== Anti-Studi ====================

model StudiConfig {
  id                 BigInt    @id @default(autoincrement())
  guildId            String    @unique @map("guild_id") @db.VarChar(50)
  enabled            Boolean   @default(false)
  autoBan            Boolean   @default(false) @map("auto_ban")
  detectionThreshold Int       @default(5) @map("detection_threshold")
  customMessage      String?   @map("custom_message") @db.Text
  updatedBy          String?   @map("updated_by") @db.VarChar(50)
  createdAt          DateTime? @map("created_at") @db.Timestamptz
  updatedAt          DateTime? @map("updated_at") @db.Timestamptz

  @@map("studi_config")
}

model StudiBannedUser {
  id          BigInt    @id @default(autoincrement())
  userId      String    @map("user_id") @db.VarChar(50)
  username    String    @db.VarChar(100)
  guildId     String    @map("guild_id") @db.VarChar(50)
  banLevel    BanLevel  @default(warn) @map("ban_level")
  reason      String?   @db.Text
  bannedBy    String    @map("banned_by") @db.VarChar(50)
  bannedAt    DateTime  @default(now()) @map("banned_at") @db.Timestamptz
  unbannedBy  String?   @map("unbanned_by") @db.VarChar(50)
  unbannedAt  DateTime? @map("unbanned_at") @db.Timestamptz
  unbanReason String?   @map("unban_reason") @db.Text
  isActive    Boolean   @default(true) @map("is_active")

  @@index([userId, guildId])
  @@index([isActive])
  @@map("studi_banned_users")
}

model StudiDetectionLog {
  id            BigInt        @id @default(autoincrement())
  userId        String        @map("user_id") @db.VarChar(50)
  username      String        @db.VarChar(100)
  guildId       String        @map("guild_id") @db.VarChar(50)
  detectionType DetectionType @map("detection_type")
  action        String        @db.VarChar(50)
  details       String?       @db.Text
  detectedAt    DateTime      @default(now()) @map("detected_at") @db.Timestamptz

  @@index([guildId, detectedAt])
  @@index([userId])
  @@map("studi_detection_logs")
}

model StudiWhitelist {
  id        BigInt    @id @default(autoincrement())
  userId    String    @map("user_id") @db.VarChar(50)
  username  String    @db.VarChar(100)
  guildId   String    @map("guild_id") @db.VarChar(50)
  addedBy   String    @map("added_by") @db.VarChar(50)
  isActive  Boolean   @default(true) @map("is_active")
  addedAt   DateTime  @default(now()) @map("added_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  @@index([userId, guildId])
  @@index([isActive])
  @@map("studi_whitelist")
}

model StudiLevelHistory {
  id        Int       @id @default(autoincrement())
  discordId String    @map("discord_id") @db.VarChar(20)
  guildId   String    @map("guild_id") @db.VarChar(20)
  oldLevel  String?   @map("old_level") @db.VarChar(50)
  newLevel  String    @map("new_level") @db.VarChar(50)
  changedBy String?   @map("changed_by") @db.VarChar(20)
  reason    String?   @db.Text
  changedAt DateTime? @default(now()) @map("changed_at") @db.Timestamptz

  @@index([discordId])
  @@index([guildId])
  @@map("studi_level_history")
}

// ==================== Suggestions & Bug Reports ====================

model Suggestion {
  id            Int              @id @default(autoincrement())
  guildId       String           @map("guild_id") @db.VarChar(50)
  userId        String           @map("user_id") @db.VarChar(50)
  text          String           @db.Text
  status        SuggestionStatus @default(PENDING)
  staffResponse String?          @map("staff_response") @db.Text
  messageId     String?          @map("message_id") @db.VarChar(50)
  channelId     String?          @map("channel_id") @db.VarChar(50)
  upvotes       Int              @default(0)
  downvotes     Int              @default(0)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@index([guildId])
  @@index([status])
  @@map("suggestions")
}

model BugReport {
  id             Int       @id @default(autoincrement())
  guildId        String    @map("guild_id") @db.VarChar(50)
  userId         String    @map("user_id") @db.VarChar(50)
  description    String?   @db.Text
  commandName    String?   @map("command_name") @db.VarChar(100)
  commandOptions Json?     @map("command_options")
  errorMessage   String?   @map("error_message") @db.Text
  status         BugStatus @default(OPEN)
  assignedTo     String?   @map("assigned_to") @db.VarChar(50)
  staffNotes     String?   @map("staff_notes") @db.Text
  messageId      String?   @map("message_id") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz

  @@index([guildId])
  @@index([status])
